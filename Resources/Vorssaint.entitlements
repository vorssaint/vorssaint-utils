<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened runtime is required for notarization. The app is NOT sandboxed
	     (its features need system-wide access gated by TCC at runtime, not by
	     entitlements). Hardened runtime blocks two capabilities the app uses:
	     sending Apple Events (cut & paste and the uninstaller drive the Finder)
	     and the camera (the preview mirror); these entitlements restore them.
	     The user still grants each one through the normal TCC prompts. -->
	<key>com.apple.security.automation.apple-events</key>
	<true/>
	<key>com.apple.security.device.camera</key>
	<true/>
</dict>
</plist>
